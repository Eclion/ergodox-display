  "productName": "Ergodox Display",
  "version": "0.1.0",
  "identifier": "io.github.eclion.ergodox-display",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
